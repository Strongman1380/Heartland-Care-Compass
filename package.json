  "scripts": {
    "dev": "concurrently -n server,web -c yellow,cyan \"PORT=3001 node server-new.js\" \"vite --port 8080\"",
    "dev:vite": "vite",
    "dev:server": "PORT=3001 node server-new.js",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "lint": "eslint .",
    "preview": "vite preview",
    "dev:full": "concurrently -n emulator,server,web -c magenta,yellow,cyan \"firebase emulators:start --only functions,firestore\" \"PORT=3001 node server-new.js\" \"vite --port 8080\"",
    "start": "firebase emulators:start",
    "predeploy": "npm run build",
    "deploy": "npm run build && firebase deploy",
    "deploy:hosting": "npm run build && firebase deploy --only hosting",
    "deploy:functions": "cd functions && npm install && cd .. && firebase deploy --only functions",
    "deploy:rules": "firebase deploy --only firestore:rules,firestore:indexes",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:all": "npm run test:unit && npm run test && npm run test:e2e"
  },
