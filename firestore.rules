rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/user_roles/$(request.auth.uid))
        && get(/databases/$(database)/documents/user_roles/$(request.auth.uid)).data.role == 'admin';
    }

    function isDraftOwner() {
      return signedIn() && resource.data.author_id == request.auth.uid;
    }

    function isDraftOwnerOnCreate() {
      return signedIn() && request.resource.data.author_id == request.auth.uid;
    }

    match /user_roles/{uid} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /report_drafts/{draftId} {
      allow create: if isDraftOwnerOnCreate();
      allow read, update, delete: if isDraftOwner();
    }

    match /level_config/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /facility_reports/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /facility_notes/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /kpi_reports/{docId} {
      allow read, write: if signedIn();
    }

    match /referral_response_tokens/{token} {
      allow read, write: if signedIn();
    }

    match /youth/{youthId} {
      allow read, create, update: if signedIn();
      allow delete: if isAdmin();

      match /{document=**} {
        allow read, write: if signedIn();
      }
    }

    match /alerts/{docId} {
      allow read, write: if signedIn();
    }

    match /notes/{docId} {
      allow read, write: if signedIn();
    }

    match /referral_notes/{docId} {
      allow read, write: if signedIn();
    }

    match /academic_credits/{docId} {
      allow read, write: if signedIn();
    }

    match /academic_grades/{docId} {
      allow read, write: if signedIn();
    }

    match /academic_steps_completed/{docId} {
      allow read, write: if signedIn();
    }

    match /school_daily_scores/{docId} {
      allow read, write: if signedIn();
    }

    match /school_incidents/{docId} {
      allow read, write: if signedIn();
    }

    match /school_incident_involved/{docId} {
      allow read, write: if signedIn();
    }

    match /facility_incidents/{docId} {
      allow read, write: if signedIn();
    }

    match /real_colors_assessments/{docId} {
      allow read, write: if signedIn();
    }

    match /incident_reports/{docId} {
      allow read, write: if signedIn();
    }

    match /incident_audit_logs/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /level_events/{docId} {
      allow read, write: if signedIn();
    }

    match /weekly_eval_scores/{docId} {
      allow read, write: if signedIn();
    }

    match /daily_shift_scores/{docId} {
      allow read, write: if signedIn();
    }

    // collectionGroup rules — required for queries that span all subcollections
    // with the same name, regardless of parent path.
    match /{path=**}/behavior_points/{docId} {
      allow read, write: if signedIn();
    }

    match /{path=**}/case_notes/{docId} {
      allow read, write: if signedIn();
    }

    match /{path=**}/daily_ratings/{docId} {
      allow read, write: if signedIn();
    }

    match /{path=**}/important_dates/{docId} {
      allow read, write: if signedIn();
    }
  }
}
